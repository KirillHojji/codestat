import os
import sys
import time
import signal
from pathlib import Path
from collections import defaultdict

VERSION = "0.3"
AUTHOR = "KirillHojji"
DESCRIPTION = "codestat - source code line counter for projects"

EXTENSIONS = {
    '.ts': 'TypeScript',
    '.tsx': 'TypeScript',
    '.js': 'JavaScript',
    '.jsx': 'JavaScript',
    '.py': 'Python',
    '.css': 'CSS',
    '.html': 'HTML',
    '.json': 'JSON',
    '.yaml': 'YAML',
    '.yml': 'YAML',
    '.md': 'Markdown',
    '.xml': 'XML',
    '.cs': 'C#',
    '.cpp': 'C++',
    '.cxx': 'C++',
    '.c': 'C',
    '.h': 'C/C++ Header',
    '.hpp': 'C/C++ Header',
    '.go': 'Go',
    '.rs': 'Rust',
    '.java': 'Java',
    '.php': 'PHP',
    '.rb': 'Ruby',
    '.swift': 'Swift',
    '.kt': 'Kotlin',
    '.sql': 'SQL',
}

DEFAULT_EXCLUDE = {
    'node_modules', '.git', '__pycache__', 'dist', 'build',
    '.venv', 'venv', 'env', '.idea', '.vscode', 'coverage',
    '.next', '.nuxt', '.cache', 'tmp', 'temp'
}

class TimeoutError(Exception):
    pass

def timeout_handler(signum, frame):
    raise TimeoutError("Timeout exceeded")

def show_help():
    print(f"""{DESCRIPTION}
Usage: codestat [OPTIONS] <directory>

Options:
  --help            Show this help message
  --version         Show version information
  --info            Show author and package information
  --timeout N       Set timeout in seconds for each file (default: 0 = no timeout)
  --exclude DIR     Exclude directory (can be used multiple times)
  --verbose         Show detailed processing information

Examples:
  codestat /path/to/project
  codestat --exclude node_modules --exclude .git /opt/Funtys
  codestat --timeout 5 --verbose ./src

Default excluded directories:
  node_modules, .git, __pycache__, dist, build, .venv, venv, env, .idea, .vscode

Report bugs to: @KirillHojji""")

def show_info():
    print(f"""Package: codestat
Version: {VERSION}
Author: {AUTHOR}
Description: {DESCRIPTION}
License: MIT
Repository: https://github.com/KirillHojji/codestat
Dependencies: Python 3.6+
Features:
  - Multi-language support
  - Comment and blank line filtering
  - Docstring handling for Python
  - Timeout protection for large files
  - Exclude directories""")

def is_excluded(path, exclude_dirs):
    parts = path.parts
    for excl in exclude_dirs:
        if excl in parts:
            return True
    return False

def count_file_lines(path, timeout_seconds=0):
    if timeout_seconds > 0:
        signal.signal(signal.SIGALRM, timeout_handler)
        signal.alarm(timeout_seconds)
    
    try:
        with open(path, 'r', encoding='utf-8', errors='ignore') as f:
            lines = f.readlines()
    except (UnicodeDecodeError, OSError):
        return (0, 0, 0, 0)
    finally:
        if timeout_seconds > 0:
            signal.alarm(0)
    
    total = len(lines)
    blank = 0
    comment = 0
    in_block_comment = False
    in_string = False
    string_char = None
    is_py = path.suffix.lower() == '.py'
    
    i = 0
    while i < total:
        raw_line = lines[i]
        line = raw_line.strip()
        
        if not line:
            blank += 1
            i += 1
            continue
        
        if in_block_comment:
            comment += 1
            if '*/' in raw_line:
                in_block_comment = False
            i += 1
            continue
        
        line_comment = False
        j = 0
        length = len(raw_line)
        while j < length:
            char = raw_line[j]
            next_char = raw_line[j+1] if j + 1 < length else ''
            
            if not in_string:
                if char == '"' and (j == 0 or raw_line[j-1] != '\\'):
                    in_string = True
                    string_char = '"'
                elif char == "'" and (j == 0 or raw_line[j-1] != '\\'):
                    in_string = True
                    string_char = "'"
                elif char == '#' and not in_string:
                    line_comment = True
                    break
                elif char == '/' and next_char == '*':
                    in_block_comment = True
                    comment += 1
                    j += 2
                    continue
            else:
                if char == string_char and (j == 0 or raw_line[j-1] != '\\'):
                    in_string = False
            j += 1
        
        if line_comment:
            comment += 1
            i += 1
            continue
        
        if is_py and not in_string:
            stripped = raw_line.lstrip()
            if stripped.startswith('"""') or stripped.startswith("'''"):
                comment += 1
                i += 1
                continue
        
        i += 1
    
    code = total - blank - comment
    return (total, code, comment, blank)

def scan_directory(root_path, timeout=0, verbose=False, exclude_dirs=None):
    if exclude_dirs is None:
        exclude_dirs = []
    
    all_exclude = DEFAULT_EXCLUDE | set(exclude_dirs)
    
    stats = defaultdict(lambda: {'files': 0, 'total': 0, 'code': 0, 'comment': 0, 'blank': 0})
    errors = []
    all_files = []
    
    for file_path in root_path.rglob('*'):
        if file_path.is_file():
            if is_excluded(file_path, all_exclude):
                continue
            ext = file_path.suffix.lower()
            if ext in EXTENSIONS:
                all_files.append(file_path)
    
    all_files.sort()
    
    print(f"     {len(all_files)} text files.")
    
    ext_counts = defaultdict(int)
    for file_path in all_files:
        ext_counts[file_path.suffix.lower()] += 1
    
    unique_count = len(ext_counts)
    print(f"Unique:      {len(all_files)} files                                     {unique_count} unique files.")
    print(f"      0 files ignored.\n")
    
    for idx, file_path in enumerate(all_files):
        if verbose and idx % 100 == 0:
            print(f"Processing: {idx}/{len(all_files)} files...", file=sys.stderr)
        
        ext = file_path.suffix.lower()
        lang = EXTENSIONS[ext]
        
        try:
            total, code, comment, blank = count_file_lines(file_path, timeout)
            if total == 0:
                errors.append(f"Line count failed: {file_path}")
                continue
            
            stats[lang]['files'] += 1
            stats[lang]['total'] += total
            stats[lang]['code'] += code
            stats[lang]['comment'] += comment
            stats[lang]['blank'] += blank
            
        except TimeoutError:
            errors.append(f"Timeout ({timeout}s): {file_path}")
        except Exception as e:
            errors.append(f"Error processing {file_path}: {str(e)}")
    
    if verbose:
        print("Done processing files.\n", file=sys.stderr)
    
    if errors:
        print(f"{len(errors)} errors:")
        for error in errors[:10]:
            print(error)
        if len(errors) > 10:
            print(f"... and {len(errors) - 10} more errors")
        print()
    
    print("-" * 90)
    print(f"{'Language':<20} {'Files':>8} {'Total':>10} {'Code':>10} {'Comment':>10} {'Blank':>10}")
    print("-" * 90)
    
    total_stats = {'files': 0, 'total': 0, 'code': 0, 'comment': 0, 'blank': 0}
    
    for lang in sorted(stats.keys()):
        data = stats[lang]
        if data['files'] > 0:
            print(f"{lang:<20} {data['files']:>8} {data['total']:>10} {data['code']:>10} {data['comment']:>10} {data['blank']:>10}")
            total_stats['files'] += data['files']
            total_stats['total'] += data['total']
            total_stats['code'] += data['code']
            total_stats['comment'] += data['comment']
            total_stats['blank'] += data['blank']
    
    print("-" * 90)
    print(f"{'SUM':<20} {total_stats['files']:>8} {total_stats['total']:>10} {total_stats['code']:>10} {total_stats['comment']:>10} {total_stats['blank']:>10}")

if __name__ == '__main__':
    args = sys.argv[1:]
    directory = None
    timeout = 0
    verbose = False
    exclude_dirs = []
    
    if not args:
        show_help()
        sys.exit(0)
    
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == '--help':
            show_help()
            sys.exit(0)
        elif arg == '--version':
            print(f"codestat version {VERSION}")
            sys.exit(0)
        elif arg == '--info':
            show_info()
            sys.exit(0)
        elif arg == '--timeout' and i + 1 < len(args):
            try:
                timeout = int(args[i + 1])
                i += 1
            except ValueError:
                print("Error: --timeout requires an integer value")
                sys.exit(1)
        elif arg == '--exclude' and i + 1 < len(args):
            exclude_dirs.append(args[i + 1])
            i += 1
        elif arg == '--verbose':
            verbose = True
        elif arg.startswith('-'):
            print(f"Unknown option: {arg}")
            print("Use --help for usage information")
            sys.exit(1)
        else:
            directory = arg
        i += 1
    
    if not directory:
        print("Error: No directory specified")
        print("Use --help for usage information")
        sys.exit(1)
    
    root_path = Path(directory)
    if not root_path.exists():
        print(f"Error: Directory {root_path} does not exist")
        sys.exit(1)
    
    scan_directory(root_path, timeout, verbose, exclude_dirs)
