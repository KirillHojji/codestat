def is_excluded(path, exclude_dirs):
    parts = path.parts
    for excl in exclude_dirs:
        if excl in parts:
            return True
    return False

def is_single_line_comment(line, lang):
    line_stripped = line.lstrip()
    if not line_stripped:
        return False
    
    if lang == 'Python':
        return line_stripped.startswith('#')
    elif lang in ['JavaScript', 'TypeScript', 'Java', 'C', 'C++', 'Go', 'Rust', 'PHP', 'C#', 'Swift', 'Kotlin', 'Scala', 'Groovy', 'Dart']:
        return line_stripped.startswith('//')
    elif lang in ['CSS', 'SQL']:
        return line_stripped.startswith('--')
    elif lang == 'Ruby':
        return line_stripped.startswith('#')
    elif lang == 'Shell':
        return line_stripped.startswith('#')
    elif lang == 'Perl':
        return line_stripped.startswith('#')
    elif lang == 'Lua':
        return line_stripped.startswith('--')
    elif lang == 'Elixir':
        return line_stripped.startswith('#')
    elif lang == 'Clojure':
        return line_stripped.startswith(';')
    elif lang == 'Haskell':
        return line_stripped.startswith('--')
    elif lang == 'R':
        return line_stripped.startswith('#')
    
    return False

def count_file_lines(path, timeout_seconds=0):
    if timeout_seconds > 0:
        signal.signal(signal.SIGALRM, timeout_handler)
        signal.alarm(timeout_seconds)

    try:
        with open(path, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            lines = content.splitlines(keepends=True)
    except (UnicodeDecodeError, OSError):
        return (0, 0, 0, 0)
    finally:
        if timeout_seconds > 0:
            signal.alarm(0)

    total = len(lines)
    blank = 0
    comment = 0
    in_multiline_comment = False
    in_docstring = False
    docstring_delimiter = None
    is_py = path.suffix.lower() == '.py'
    lang = EXTENSIONS.get(path.suffix.lower(), 'Unknown')
    
    i = 0
    while i < total:
        line = lines[i]
        line_stripped = line.strip()
        
        if not line_stripped:
            blank += 1
            i += 1
            continue
        
        if in_multiline_comment:
            comment += 1
            if '*/' in line:
                in_multiline_comment = False
            i += 1
            continue
        
        if in_docstring:
            comment += 1
            if docstring_delimiter in line:
                in_docstring = False
                docstring_delimiter = None
            i += 1
            continue
        
        j = 0
        line_comment = False
        in_string = False
        string_char = None
        length = len(line)
        
        while j < length:
            char = line[j]
            next_char = line[j+1] if j+1 < length else ''
            next_next_char = line[j+2] if j+2 < length else ''
            
            if not in_string:
                if char == '"' and (j == 0 or line[j-1] != '\\'):
                    if is_py and next_char == '"' and next_next_char == '"':
                        in_docstring = True
                        docstring_delimiter = '"""'
                        comment += 1
                        j += 3
                        break
                    in_string = True
                    string_char = '"'
                elif char == "'" and (j == 0 or line[j-1] != '\\'):
                    if is_py and next_char == "'" and next_next_char == "'":
                        in_docstring = True
                        docstring_delimiter = "'''"
                        comment += 1
                        j += 3
                        break
                    in_string = True
                    string_char = "'"
                elif char == '/' and next_char == '*':
                    in_multiline_comment = True
                    comment += 1
                    j += 2
                    break
                elif char == '/' and next_char == '/':
                    line_comment = True
                    break
                elif char == '#':
                    line_comment = True
                    break
                elif char == '-' and next_char == '-':
                    line_comment = True
                    break
                elif char == ';':
                    line_comment = True
                    break
            else:
                if char == string_char and (j == 0 or line[j-1] != '\\'):
                    in_string = False
            j += 1
        
        if line_comment:
            comment += 1
            i += 1
            continue
        
        if not in_multiline_comment and not in_docstring:
            if is_single_line_comment(line, lang):
                comment += 1
                i += 1
                continue
        
        i += 1
    
    code = total - blank - comment
    return (total, code, comment, blank)

def analyze_single_file(file_path, timeout=0, verbose=False):
    if verbose:
        print(f"Analyzing: {file_path}", file=sys.stderr)
    
    ext = file_path.suffix.lower()
    if ext not in EXTENSIONS:
        print(f"Error: Unsupported file type: {ext}")
        print("Supported extensions: " + ', '.join(sorted(EXTENSIONS.keys())))
        sys.exit(1)
    
    language = EXTENSIONS[ext]
    
    try:
        total, code, comment, blank = count_file_lines(file_path, timeout)
    except TimeoutError:
        print(f"Error: Timeout ({timeout}s) exceeded while processing {file_path}")
        sys.exit(1)
    except Exception as e:
        print(f"Error processing {file_path}: {str(e)}")
        sys.exit(1)
    
    if total == 0:
        print("Error: File is empty or could not be read")
        sys.exit(1)
    
    code_percent = (code / total) * 100
    comment_percent = (comment / total) * 100
    blank_percent = (blank / total) * 100
    
    print("\n" + "=" * 60)
    print(f"FILE ANALYSIS: {file_path.name}")
    print("=" * 60)
    print(f"Full path:     {file_path.absolute()}")
    print(f"Language:      {language}")
    print(f"Extension:     {ext}")
    print("-" * 60)
    print(f"Total lines:   {total}")
    print(f"Code lines:    {code} ({code_percent:.1f}%)")
    print(f"Comment lines: {comment} ({comment_percent:.1f}%)")
    print(f"Blank lines:   {blank} ({blank_percent:.1f}%)")
    print("-" * 60)
    
    if verbose:
        print("\nDetailed parsing information was enabled with --verbose")
    
    print("=" * 60 + "\n")

def scan_directory(root_path, timeout=0, verbose=False, exclude_dirs=None, sort_by=None):
    if exclude_dirs is None:
        exclude_dirs = []

    all_exclude = DEFAULT_EXCLUDE | set(exclude_dirs)

    stats = defaultdict(lambda: {'files': 0, 'total': 0, 'code': 0, 'comment': 0, 'blank': 0})
    errors = []
    all_files = []

    for file_path in root_path.rglob('*'):
        if file_path.is_file():
            if is_excluded(file_path, all_exclude):
                continue
            ext = file_path.suffix.lower()
            if ext in EXTENSIONS:
                all_files.append(file_path)

    all_files.sort()

    print(f"     {len(all_files)} text files.")

    ext_counts = defaultdict(int)
    for file_path in all_files:
        ext_counts[file_path.suffix.lower()] += 1

    unique_count = len(ext_counts)
    print(f"Unique:      {len(all_files)} files                                     {unique_count} unique files.")
    print(f"      0 files ignored.\n")

    for idx, file_path in enumerate(all_files):
        if verbose and idx % 100 == 0:
            print(f"Processing: {idx}/{len(all_files)} files...", file=sys.stderr)

        ext = file_path.suffix.lower()
        lang = EXTENSIONS[ext]

        try:
            total, code, comment, blank = count_file_lines(file_path, timeout)
            if total == 0:
                errors.append(f"Line count failed: {file_path}")
                continue

            stats[lang]['files'] += 1
            stats[lang]['total'] += total
            stats[lang]['code'] += code
            stats[lang]['comment'] += comment
            stats[lang]['blank'] += blank

        except TimeoutError:
            errors.append(f"Timeout ({timeout}s): {file_path}")
        except Exception as e:
            errors.append(f"Error processing {file_path}: {str(e)}")

    if verbose:
        print("Done processing files.\n", file=sys.stderr)

    if errors:
        print(f"{len(errors)} errors:")
        for error in errors[:10]:
            print(error)
        if len(errors) > 10:
            print(f"... and {len(errors) - 10} more errors")
        print()

    items = list(stats.items())
    if sort_by and sort_by in ['files', 'total', 'code', 'comment', 'blank']:
        items.sort(key=lambda x: x[1][sort_by], reverse=True)
    else:
        items.sort(key=lambda x: x[0])

    print("-" * 90)
    print(f"{'Language':<20} {'Files':>8} {'Total':>10} {'Code':>10} {'Comment':>10} {'Blank':>10}")
    print("-" * 90)

    total_stats = {'files': 0, 'total': 0, 'code': 0, 'comment': 0, 'blank': 0}

    for lang, data in items:
        if data['files'] > 0:
            print(f"{lang:<20} {data['files']:>8} {data['total']:>10} {data['code']:>10} {data['comment']:>10} {data['blank']:>10}")
            total_stats['files'] += data['files']
            total_stats['total'] += data['total']
            total_stats['code'] += data['code']
            total_stats['comment'] += data['comment']
            total_stats['blank'] += data['blank']

    print("-" * 90)
    print(f"{'SUM':<20} {total_stats['files']:>8} {total_stats['total']:>10} {total_stats['code']:>10} {total_stats['comment']:>10} {total_stats['blank']:>10}")

if __name__ == '__main__':
    args = sys.argv[1:]
    path = None
    timeout = 0
    verbose = False
    exclude_dirs = []
    sort_by = None

    if not args:
        show_help()
        sys.exit(0)

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == '--help':
            show_help()
            sys.exit(0)
        elif arg == '--version':
            print(f"codestat version {VERSION}")
            sys.exit(0)
        elif arg == '--info':
            show_info()
            sys.exit(0)
        elif arg == '--timeout' and i + 1 < len(args):
            try:
                timeout = int(args[i + 1])
                i += 1
            except ValueError:
                print("Error: --timeout requires an integer value")
                sys.exit(1)
        elif arg == '--exclude' and i + 1 < len(args):
            exclude_dirs.append(args[i + 1])
            i += 1
        elif arg == '--verbose':
            verbose = True
        elif arg == '--sort' and i + 1 < len(args):
            sort_by = args[i + 1]
            if sort_by not in ['files', 'total', 'code', 'comment', 'blank']:
                print(f"Error: --sort must be one of: files, total, code, comment, blank")
                sys.exit(1)
            i += 1
        elif arg.startswith('-'):
            print(f"Unknown option: {arg}")
            print("Use --help for usage information")
            sys.exit(1)
        else:
            path = arg
        i += 1

    if not path:
        print("Error: No path specified")
        print("Use --help for usage information")
        sys.exit(1)

    path_obj = Path(path)
    if not path_obj.exists():
        print(f"Error: Path {path_obj} does not exist")
        sys.exit(1)

    if path_obj.is_file():
        if exclude_dirs:
            print("Warning: --exclude option is ignored for single file analysis")
        if sort_by:
            print("Warning: --sort option is ignored for single file analysis")
        analyze_single_file(path_obj, timeout, verbose)
    elif path_obj.is_dir():
        scan_directory(path_obj, timeout, verbose, exclude_dirs, sort_by)
    else:
        print(f"Error: {path_obj} is neither a file nor a directory")
        sys.exit(1)
